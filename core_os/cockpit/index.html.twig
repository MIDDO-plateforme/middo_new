{% extends 'base.html.twig' %}

{% block body %}
<div style="display:flex;min-height:80vh;">

    {# Sidebar cockpit #}
    {% include 'core_os/cockpit/_sidebar.html.twig' %}

    <div style="flex:1;padding:2rem;">
        <h1>Cockpit MIDDO</h1>
        <p style="opacity:0.7;">Vue d’ensemble en temps réel</p>

        <hr style="margin:1.5rem 0;">

        {# Carte Leaflet + filtres + transporteurs + segments #}
        {% include 'core_os/cockpit/_map.html.twig' %}

        <hr style="margin:2rem 0;">

        {# Cartes statistiques #}
        {% include 'core_os/cockpit/_stats_cards.html.twig' with { stats: stats } %}

        <hr style="margin:2rem 0;">

        {# Mises à jour en temps réel (alertes Mercure) #}
        {% include 'core_os/cockpit/_live_updates.html.twig' %}
        <script src="/js/mercure.js"></script>
    </div>
</div>
{% endblock %}
