<div class="ia-panel">

    <div class="ia-panel-header">
        <h3 class="ia-title">Assistant IA</h3>
        <button class="ia-close" aria-label="Fermer le panneau IA">×</button>
    </div>

    <div class="ia-panel-body">

        <div class="ia-section">
            <h4>🧠 Actions rapides</h4>
            <div class="ia-actions">
                <button class="btn-soft ia-action">Résumer</button>
                <button class="btn-soft ia-action">Expliquer</button>
                <button class="btn-soft ia-action">Traduire</button>
                <button class="btn-soft ia-action">Classer</button>
                <button class="btn-soft ia-action">Extraire</button>
            </div>
        </div>

        <div class="ia-section">
            <h4>📄 Contexte actuel</h4>
            <p class="ia-context">
                Aucun contexte chargé. Sélectionnez un fichier, un texte ou une zone pour activer l’IA.
            </p>
        </div>

        <div class="ia-section">
            <h4>💬 Conversation</h4>
            <div class="ia-chat">
                <div class="ia-chat-empty">
                    L’assistant est prêt. Posez une question ou sélectionnez une action IA.
                </div>
            </div>

            <div class="ia-chat-input">
                <input type="text" placeholder="Demander quelque chose à l’IA…" aria-label="Message IA">
                <button class="btn-primary">Envoyer</button>
            </div>
        </div>

    </div>

</div>
