{% extends 'base.html.twig' %}

{% block title %}Projet {{ project.name }}{% endblock %}

{% block body %}
<div style="padding:20px; max-width:700px; margin:auto;">

    <h1>Détails du projet</h1>

    <ul>
        <li>ID : {{ project.id }}</li>
        <li>Nom : {{ project.name }}</li>
        <li>Propriétaire : {{ project.owner }}</li>
        <li>Créé le : {{ project.created_at }}</li>
    </ul>

    <p>
        <a href="{{ path('admin.projects.index') }}">← Retour à la liste</a>
    </p>

</div>
{% endblock %}
