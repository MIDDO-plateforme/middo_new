{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block body %}
<div style="padding:20px; max-width:900px; margin:auto;">

    <h1>Dashboard Administrateur</h1>

    <div style="display:flex; gap:20px; flex-wrap:wrap; margin-top:20px;">

        <div style="flex:1; min-width:200px; padding:20px; border:1px solid #ddd; border-radius:8px;">
            <h3>Utilisateurs</h3>
            <p style="font-size:24px; font-weight:bold;">{{ stats.users }}</p>
        </div>

        <div style="flex:1; min-width:200px; padding:20px; border:1px solid #ddd; border-radius:8px;">
            <h3>Projets</h3>
            <p style="font-size:24px; font-weight:bold;">{{ stats.projects }}</p>
        </div>

        <div style="flex:1; min-width:200px; padding:20px; border:1px solid #ddd; border-radius:8px;">
            <h3>Messages</h3>
            <p style="font-size:24px; font-weight:bold;">{{ stats.messages }}</p>
        </div>

        <div style="flex:1; min-width:200px; padding:20px; border:1px solid #ddd; border-radius:8px;">
            <h3>Requêtes IA</h3>
            <p style="font-size:24px; font-weight:bold;">{{ stats.ia_requests }}</p>
        </div>

    </div>

</div>
{% endblock %}
