{% extends 'base.html.twig' %}

{% block title %}Informations système{% endblock %}

{% block body %}
<div style="padding:20px; max-width:800px; margin:auto;">

    <h1>Informations système</h1>

    <ul>
        <li><strong>Système d'exploitation :</strong> {{ system.os }}</li>
        <li><strong>Version PHP :</strong> {{ system.php_version }}</li>
        <li><strong>Version MIDDO OS :</strong> {{ system.middo_version }}</li>
        <li><strong>Mémoire utilisée :</strong> {{ system.memory_usage }}</li>
        <li><strong>Espace disque libre :</strong> {{ system.disk_space }}</li>
    </ul>

</div>
{% endblock %}
