{% extends 'base.html.twig' %}

{% block title %}Logs système{% endblock %}

{% block body %}
<div style="padding:20px; max-width:900px; margin:auto;">

    <h1>Logs système</h1>

    <table border="1" cellpadding="10" cellspacing="0" width="100%">
        <thead>
            <tr>
                <th>Niveau</th>
                <th>Message</th>
                <th>Contexte</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>
            {% for log in logs %}
                <tr>
                    <td>{{ log.level }}</td>
                    <td>{{ log.message }}</td>
                    <td>{{ log.context }}</td>
                    <td>{{ log.created_at|date('d/m/Y H:i') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}
