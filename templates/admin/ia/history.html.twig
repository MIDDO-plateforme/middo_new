{% extends 'base.html.twig' %}

{% block title %}Historique IA{% endblock %}

{% block body %}
<div style="padding:20px; max-width:900px; margin:auto;">

    <h1>Historique des requêtes IA</h1>

    <table border="1" cellpadding="10" cellspacing="0" width="100%">
        <thead>
            <tr>
                <th>ID</th>
                <th>Prompt</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>
            {% for row in history %}
                <tr>
                    <td>{{ row.id }}</td>
                    <td>{{ row.prompt }}</td>
                    <td>{{ row.date }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}
