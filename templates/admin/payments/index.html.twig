{% extends 'base.html.twig' %}

{% block title %}Paiements — Administration{% endblock %}

{% block body %}
<div style="padding:20px; max-width:900px; margin:auto;">

    <h1>Liste des paiements</h1>

    <table border="1" cellpadding="10" cellspacing="0" width="100%">
        <thead>
            <tr>
                <th>ID</th>
                <th>Utilisateur</th>
                <th>Montant</th>
                <th>Statut</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            {% for p in payments %}
                <tr>
                    <td>{{ p.id }}</td>
                    <td>{{ p.user }}</td>
                    <td>{{ p.amount }} €</td>
                    <td>{{ p.status }}</td>
                    <td>{{ p.date }}</td>
                    <td>
                        <a href="{{ path('admin.payments.view', {id: p.id}) }}">Voir</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}
