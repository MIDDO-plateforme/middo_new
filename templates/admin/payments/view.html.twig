{% extends 'base.html.twig' %}

{% block title %}Paiement #{{ payment.id }}{% endblock %}

{% block body %}
<div style="padding:20px; max-width:700px; margin:auto;">

    <h1>Détails du paiement</h1>

    <ul>
        <li><strong>ID :</strong> {{ payment.id }}</li>
        <li><strong>Utilisateur :</strong> {{ payment.user }}</li>
        <li><strong>Montant :</strong> {{ payment.amount }} €</li>
        <li><strong>Statut :</strong> {{ payment.status }}</li>
        <li><strong>Méthode :</strong> {{ payment.method }}</li>
        <li><strong>Transaction :</strong> {{ payment.transaction_id }}</li>
        <li><strong>Date :</strong> {{ payment.date }}</li>
    </ul>

    <p>
        <a href="{{ path('admin.payments.index') }}">← Retour aux paiements</a>
    </p>

</div>
{% endblock %}
