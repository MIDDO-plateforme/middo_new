{% extends 'base.html.twig' %}

{% block title %}Utilisateur #{{ user.id }}{% endblock %}

{% block body %}
<div style="padding:20px; max-width:700px; margin:auto;">

    <h1>Détails de l’utilisateur</h1>

    <ul>
        <li><strong>ID :</strong> {{ user.id }}</li>
        <li><strong>Email :</strong> {{ user.email }}</li>
        <li><strong>Rôle :</strong> {{ user.role }}</li>
        <li><strong>Créé le :</strong> {{ user.created_at }}</li>
    </ul>

    <p>
        <a href="{{ path('admin.users.index') }}">← Retour à la liste</a>
    </p>

</div>
{% endblock %}
