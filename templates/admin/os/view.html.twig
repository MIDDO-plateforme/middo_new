{% extends 'base.html.twig' %}

{% block title %}Module {{ module.name }}{% endblock %}

{% block body %}
<div style="padding:20px; max-width:700px; margin:auto;">

    <h1>Module : {{ module.name }}</h1>

    <ul>
        <li><strong>Statut :</strong> {{ module.status }}</li>
        <li><strong>Version :</strong> {{ module.version }}</li>
        <li><strong>Dernière mise à jour :</strong> {{ module.last_update }}</li>
        <li><strong>Description :</strong> {{ module.description }}</li>
    </ul>

    <p>
        <a href="{{ path('admin.os.index') }}">← Retour aux modules</a>
    </p>

</div>
{% endblock %}
