{% extends 'base.html.twig' %}

{% block title %}Notifications — Administration{% endblock %}

{% block body %}
<div style="padding:20px; max-width:900px; margin:auto;">

    <h1>Notifications</h1>

    <table border="1" cellpadding="10" cellspacing="0" width="100%">
        <thead>
            <tr>
                <th>ID</th>
                <th>Titre</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            {% for n in notifications %}
                <tr>
                    <td>{{ n.id }}</td>
                    <td>{{ n.title }}</td>
                    <td>{{ n.date }}</td>
                    <td>
                        <a href="{{ path('admin.notifications.view', {id: n.id}) }}">Voir</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}
