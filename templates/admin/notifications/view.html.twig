{% extends 'base.html.twig' %}

{% block title %}Notification #{{ notification.id }}{% endblock %}

{% block body %}
<div style="padding:20px; max-width:700px; margin:auto;">

    <h1>{{ notification.title }}</h1>

    <p><strong>Date :</strong> {{ notification.date }}</p>

    <p>{{ notification.content }}</p>

    <p>
        <a href="{{ path('admin.notifications.index') }}">← Retour aux notifications</a>
    </p>

</div>
{% endblock %}
