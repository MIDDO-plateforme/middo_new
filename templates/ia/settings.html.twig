{% extends 'base/layout.html.twig' %}

{% set page_title = 'Paramètres IA' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'Paramètres du module IA',
        content: '
            Configuration du comportement de l’IA : modèle, température, limites et options avancées.
        '
    } %}

    <h2 style="margin-bottom:15px;">Configuration actuelle</h2>

    {% include 'components/table.html.twig' with {
        headers: ['Paramètre', 'Valeur'],
        rows: [
            ['Modèle', settings.model],
            ['Température', settings.temperature],
            ['Max Tokens', settings.max_tokens],
            ['Top P', settings.top_p],
            ['Fréquence Penalty', settings.frequency_penalty],
            ['Présence Penalty', settings.presence_penalty]
        ]
    } %}

    <h2 style="margin-top:40px; margin-bottom:15px;">Modifier les paramètres</h2>

    <form method="post" action="/ia/settings/update">

        <div class="form-group">
            <label>Modèle</label>
            <input type="text" name="model" value="{{ settings.model }}" required>
        </div>

        <div class="form-group">
            <label>Température</label>
            <input type="number" step="0.1" name="temperature" value="{{ settings.temperature }}" required>
        </div>

        <div class="form-group">
            <label>Max Tokens</label>
            <input type="number" name="max_tokens" value="{{ settings.max_tokens }}" required>
        </div>

        <button class="btn-primary" type="submit">Enregistrer</button>
    </form>

{% endblock %}
