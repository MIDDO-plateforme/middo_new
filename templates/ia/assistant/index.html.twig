{% extends 'base.html.twig' %}

{% block title %}Assistant IA{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>{{ title }}</h1>
    <p class="text-muted">{{ subtitle }}</p>

    <div class="row">
        <div class="col-md-8">
            <div id="chat-box" class="border rounded p-3 mb-3" style="height: 350px; overflow-y: auto; background: #fafafa;">
                <div class="text-muted">Démarrez une conversation…</div>
            </div>

            <form id="chat-form">
                <div class="input-group">
                    <input type="text" id="message" class="form-control" placeholder="Écrivez votre message…">
                    <button class="btn btn-primary" type="submit">Envoyer</button>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">Contexte IA</div>
                <div class="card-body" id="ia-context">
                    Chargement du contexte…
                </div>
            </div>
        </div>
    </div>
</div>

<script>
async function loadContext() {
    try {
        const response = await fetch('/ia/assistant/api/context');
        const data = await response.json();

        if (data.success) {
            const ctx = data.context;
            document.getElementById('ia-context').innerHTML = `
                <strong>Utilisateur :</strong> ${ctx.user}<br>
                <strong>Workspace :</strong> ${ctx.workspace}<br>
                <strong>Projet actif :</strong> ${ctx.active_project ?? 'Aucun'}<br>
                <strong>Modules :</strong><br>
                <ul>
                    ${Object.entries(ctx.modules).map(([k, v]) => v ? `<li>${k}</li>` : '').join('')}
                </ul>
                <strong>Environnement :</strong> ${ctx.system.environment}<br>
                <strong>PHP :</strong> ${ctx.system.php_version}
            `;
        } else {
            document.getElementById('ia-context').innerHTML = 'Erreur de chargement du contexte.';
        }
    } catch (e) {
        document.getElementById('ia-context').innerHTML = 'Erreur de chargement du contexte.';
    }
}

document.getElementById('chat-form').addEventListener('submit', async function(e) {
    e.preventDefault();

    const message = document.getElementById('message').value.trim();
    if (!message) return;

    const chatBox = document.getElementById('chat-box');
    chatBox.innerHTML += `<div><strong>Vous :</strong> ${message}</div>`;

    const response = await fetch('/ia/assistant/api/message', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'message=' + encodeURIComponent(message)
    });

    const data = await response.json();

    if (data.success) {
        chatBox.innerHTML += `<div class="mt-2"><strong>IA :</strong> ${data.response.reply}</div>`;
    } else {
        chatBox.innerHTML += `<div class="text-danger mt-2">Erreur : ${data.error}</div>`;
    }

    chatBox.scrollTop = chatBox.scrollHeight;
    document.getElementById('message').value = '';
});

loadContext();
</script>
{% endblock %}
