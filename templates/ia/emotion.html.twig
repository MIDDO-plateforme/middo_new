{% extends 'layout/layout.html.twig' %}

{% block title %}IA Émotion — MIDDO{% endblock %}
{% block page_title %}IA Émotion{% endblock %}

{% block content %}
<div class="page">
    <h2>Analyse d’émotion</h2>
    <p>Détecte l’émotion dominante dans un texte.</p>

    <form id="ia-emotion-form">
        <textarea id="ia-emotion-text" placeholder="Texte à analyser…"></textarea>
        <button type="button" onclick="iaEmotion()">Analyser</button>
    </form>

    <pre id="ia-emotion-result"></pre>
</div>

<script>
async function iaEmotion() {
    const text = document.getElementById('ia-emotion-text').value;
    const res = await fetch('/api/ia/emotion/detect', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ text })
    });
    const data = await res.json();
    document.getElementById('ia-emotion-result').textContent = data.content ?? JSON.stringify(data, null, 2);
}
</script>
{% endblock %}
