{% extends 'base/layout.html.twig' %}

{% set page_title = 'Intelligence Artificielle' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'Module IA',
        content: '
            Interface principale pour interagir avec l’IA : requêtes, réponses, historique et paramètres.
        '
    } %}

    <h2 style="margin-bottom:15px;">Nouvelle requête</h2>

    <form method="post" action="/ia/query">
        <div class="form-group">
            <label>Votre question</label>
            <textarea name="prompt" rows="4" required></textarea>
        </div>
        <button class="btn-primary" type="submit">Envoyer</button>
    </form>

    <h2 style="margin-top:40px; margin-bottom:15px;">Dernières réponses</h2>

    {% set rows = [] %}
    {% for item in last_responses %}
        {% set rows = rows|merge([[
            item.prompt,
            item.response|slice(0, 80) ~ '...',
            item.created_at|date('d/m/Y H:i'),
            '<a href="/ia/history/' ~ item.id ~ '">Voir</a>'
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['Question', 'Réponse', 'Date', 'Actions'],
        rows: rows
    } %}

{% endblock %}
