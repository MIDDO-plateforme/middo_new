{% extends 'layout/layout.html.twig' %}

{% block title %}IA Traduction — MIDDO{% endblock %}
{% block page_title %}IA Traduction{% endblock %}

{% block content %}
<div class="page">
    <h2>Traduction intelligente</h2>
    <p>Traduction naturelle, adaptée au contexte.</p>

    <form id="ia-translate-form">
        <textarea id="ia-translate-text" placeholder="Texte à traduire…"></textarea>
        <select id="ia-translate-target">
            <option value="fr">Français</option>
            <option value="en">Anglais</option>
            <option value="es">Espagnol</option>
        </select>
        <button type="button" onclick="iaTranslate()">Traduire</button>
    </form>

    <pre id="ia-translate-result"></pre>
</div>

<script>
async function iaTranslate() {
    const text = document.getElementById('ia-translate-text').value;
    const target = document.getElementById('ia-translate-target').value;
    const res = await fetch('/api/ia/translate/text', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ text, target })
    });
    const data = await res.json();
    document.getElementById('ia-translate-result').textContent = data.content ?? JSON.stringify(data, null, 2);
}
</script>
{% endblock %}
