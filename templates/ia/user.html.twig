{% extends 'layout/layout.html.twig' %}

{% block title %}IA Profil — MIDDO{% endblock %}
{% block page_title %}IA Profil{% endblock %}

{% block content %}
<div class="page">
    <h2>Résumé IA du profil</h2>
    <p>Analyse et synthèse du profil utilisateur.</p>

    <button type="button" onclick="iaUserSummary()">Générer le résumé IA</button>

    <pre id="ia-user-result"></pre>
</div>

<script>
async function iaUserSummary() {
    const user = {{ userData|json_encode|raw }};
    const res = await fetch('/api/ia/user/summary', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ user })
    });
    const data = await res.json();
    document.getElementById('ia-user-result').textContent = data.content ?? JSON.stringify(data, null, 2);
}
</script>
{% endblock %}
