<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        {% block title %}MIDDO OS{% endblock %}
    </title>

    {# --- CSS GLOBAL --- #}
    <link rel="stylesheet" href="/assets/css/app.css">

    {# Fallback visuel si le CSS global est cassé #}
    <style>
        html, body {
            background: #f5f5f5;
            color: #222;
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
        }

        /* Thème clair */
        body.theme-light {
            background: #ffffff;
            color: #222;
        }

        /* Thème sombre (si tu l'actives plus tard) */
        body.theme-dark {
            background: #121212;
            color: #e5e5e5;
        }
    </style>

    {# --- CSS SPÉCIFIQUE (si nécessaire) --- #}
    {% block stylesheets %}{% endblock %}
</head>

<body class="theme-light">

    {% block body %}{% endblock %}

    {# --- JS GLOBAL --- #}
    <script src="/assets/js/app.js"></script>

    {# --- JS SPÉCIFIQUE (si nécessaire) --- #}
    {% block javascripts %}{% endblock %}

</body>
</html>

