<table class="table">
    <thead>
        <tr>
            {% for head in headers %}
                <th>{{ head }}</th>
            {% endfor %}
        </tr>
    </thead>

    <tbody>
        {% for row in rows %}
            <tr>
                {% for cell in row %}
                    <td>{{ cell|raw }}</td>
                {% endfor %}
            </tr>
        {% endfor %}
    </tbody>
</table>
