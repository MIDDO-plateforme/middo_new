<div class="mdo-search-bar">

    <form action="{{ path('search_results') }}" method="GET" class="mdo-search-form">

        <div class="mdo-search-input-wrapper">
            <i class="bi bi-search mdo-search-icon"></i>

            <input
                type="text"
                name="q"
                id="mdoSearchInput"
                value="{{ query|default('') }}"
                placeholder="Rechercher dans MIDDO OS…"
                class="mdo-search-input"
                autocomplete="off"
            />
        </div>

        <button class="btn btn-primary mdo-search-btn">
            Rechercher
        </button>

    </form>

    {% if suggestions is defined and suggestions %}
        <div class="mdo-search-suggestions">
            {% for s in suggestions %}
                <span class="mdo-search-suggestion" data-value="{{ s }}">{{ s }}</span>
            {% endfor %}
        </div>
    {% endif %}

    {% if history is defined and history %}
        <div class="mdo-search-history">
            <h4>Historique</h4>
            <div class="mdo-search-history-list">
                {% for h in history %}
                    <span class="mdo-search-history-item" data-value="{{ h }}">{{ h }}</span>
                {% endfor %}
            </div>
        </div>
    {% endif %}

</div>
