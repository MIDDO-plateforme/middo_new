{% extends 'base/layout.html.twig' %}

{% set page_title = 'Logs OS' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'Logs du système MIDDO OS',
        content: '
            Historique des événements internes du système : erreurs, warnings, opérations critiques et informations techniques.
        '
    } %}

    <h2 style="margin-bottom:15px;">Événements récents</h2>

    {% set rows = [] %}
    {% for log in os_logs %}
        {% set rows = rows|merge([[
            log.level|upper,
            log.message,
            log.context ?: 'Aucun',
            log.created_at|date('d/m/Y H:i')
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['Niveau', 'Message', 'Contexte', 'Date'],
        rows: rows
    } %}

{% endblock %}
