{% extends 'base/layout.html.twig' %}

{% set page_title = 'État du système' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'État global du système',
        content: '
            Voici un aperçu en temps réel de l&apos;état du système : CPU, mémoire, disque, uptime et services critiques.  
            Ces informations permettent de surveiller la stabilité et les performances de MIDDO OS.
        '
    } %}

    <h2 style="margin-bottom:15px;">Ressources système</h2>

    {% include 'components/table.html.twig' with {
        headers: ['Ressource', 'Valeur'],
        rows: [
            ['CPU utilisé', system.cpu_usage ~ ' %'],
            ['Mémoire utilisée', system.memory_used ~ ' / ' ~ system.memory_total],
            ['Disque utilisé', system.disk_used ~ ' / ' ~ system.disk_total],
            ['Uptime', system.uptime]
        ]
    } %}

    <h2 style="margin-top:40px; margin-bottom:15px;">Services critiques</h2>

    {% set rows = [] %}
    {% for service in system.critical_services %}
        {% set rows = rows|merge([[
            service.name,
            include('components/badge.html.twig', { type: service.running ? 'success' : 'danger', label: service.running ? 'En cours' : 'Arrêté' }),
            service.description
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['Service', 'Statut', 'Description'],
        rows: rows
    } %}

{% endblock %}
