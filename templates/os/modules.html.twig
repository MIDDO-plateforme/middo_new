{% extends 'base/layout.html.twig' %}

{% set page_title = 'Modules MIDDO OS' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'Modules MIDDO OS',
        content: '
            Voici la liste complète des modules intégrés dans MIDDO OS.  
            Chaque module possède un statut, une version et éventuellement des dépendances.
        '
    } %}

    <h2 style="margin-bottom:15px;">Liste des modules</h2>

    {% set rows = [] %}

    {% for module in modules %}
        {% set rows = rows|merge([[
            module.name,
            include('components/badge.html.twig', { type: module.enabled ? 'success' : 'danger', label: module.enabled ? 'Actif' : 'Inactif' }),
            module.version,
            module.dependencies|length > 0 ? module.dependencies|join(', ') : 'Aucune'
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['Module', 'Statut', 'Version', 'Dépendances'],
        rows: rows
    } %}

{% endblock %}
