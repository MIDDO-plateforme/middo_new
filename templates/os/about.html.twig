{% extends 'base/layout.html.twig' %}

{% set page_title = 'À propos de MIDDO OS' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'À propos de MIDDO OS',
        content: '
            MIDDO OS est un système modulaire conçu pour la performance, la sécurité et l&apos;extensibilité.  
            Cette page présente les informations générales, le versioning, les crédits et les licences.
        '
    } %}

    <h2 style="margin-bottom:15px;">Informations générales</h2>

    {% include 'components/table.html.twig' with {
        headers: ['Élément', 'Valeur'],
        rows: [
            ['Nom du système', about.name],
            ['Version', about.version],
            ['Version API', about.api_version],
            ['Auteur', about.author],
            ['Licence', about.license],
            ['Date de build', about.build_date],
            ['Hash de build', about.build_hash]
        ]
    } %}

    <h2 style="margin-top:40px; margin-bottom:15px;">Crédits</h2>

    {% set credit_rows = [] %}
    {% for credit in about.credits %}
        {% set credit_rows = credit_rows|merge([[
            credit.name,
            credit.role,
            credit.contribution
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['Nom', 'Rôle', 'Contribution'],
        rows: credit_rows
    } %}

    <h2 style="margin-top:40px; margin-bottom:15px;">Modules inclus</h2>

    {% set module_rows = [] %}
    {% for module in about.modules %}
        {% set module_rows = module_rows|merge([[
            module.name,
            module.version,
            module.description
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['Module', 'Version', 'Description'],
        rows: module_rows
    } %}

{% endblock %}
