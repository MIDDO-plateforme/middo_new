<div class="header">

    <!-- Bouton mobile pour ouvrir la sidebar -->
    <button onclick="toggleSidebar()" 
            style="background:none; border:none; color:#fff; font-size:22px; cursor:pointer; display:none;"
            id="mobileMenuBtn">
        ☰
    </button>

    <div style="font-size:18px; font-weight:600;">
        {% block header_title %}MIDDO OS{% endblock %}
    </div>

    <div style="display:flex; align-items:center; gap:20px;">

        <!-- Icône notifications -->
        <a href="/notifications" style="color:#bbb; text-decoration:none; font-size:20px;">
            🔔
        </a>

        <!-- Icône utilisateur -->
        <a href="/user/profile" style="color:#bbb; text-decoration:none; font-size:20px;">
            👤
        </a>

    </div>
</div>

<style>
    @media (max-width: 900px) {
        #mobileMenuBtn {
            display: block;
        }
    }
</style>
