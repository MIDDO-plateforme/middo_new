{% extends 'base/layout.html.twig' %}

{% set page_title = 'Paiements' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'Historique des paiements',
        content: '
            Liste complète des transactions, montants, statuts et dates.
        '
    } %}

    {% set rows = [] %}
    {% for pay in payments %}
        {% set rows = rows|merge([[
            pay.reference,
            pay.amount ~ ' €',
            pay.status|capitalize,
            pay.created_at|date('d/m/Y H:i'),
            '<a href="/payment/' ~ pay.id ~ '">Voir</a>'
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['Référence', 'Montant', 'Statut', 'Date', 'Actions'],
        rows: rows
    } %}

{% endblock %}
