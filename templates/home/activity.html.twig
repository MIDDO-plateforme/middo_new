{% extends 'base.html.twig' %}

{% block title %}Activité{% endblock %}

{% block body %}
<div style="padding:20px; max-width:900px; margin:auto;">

    <h1>Activité complète</h1>

    <table border="1" cellpadding="10" cellspacing="0" width="100%">
        <thead>
            <tr>
                <th>Type</th>
                <th>Description</th>
                <th>Utilisateur</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>
            {% for a in activity %}
                <tr>
                    <td>{{ a.type }}</td>
                    <td>{{ a.description }}</td>
                    <td>{{ a.user.name }}</td>
                    <td>{{ a.created_at|date('d/m/Y H:i') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <p style="margin-top:20px;">
        <a href="{{ path('home_index') }}">← Retour au dashboard</a>
    </p>

</div>
{% endblock %}
