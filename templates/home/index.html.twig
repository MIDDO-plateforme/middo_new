{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div style="padding:20px; max-width:1000px; margin:auto;">

    <h1>Dashboard</h1>

    <div style="display:flex; gap:20px; flex-wrap:wrap; margin-top:20px;">

        <div style="flex:1; min-width:200px; padding:20px; border:1px solid #ddd; border-radius:8px;">
            <h3>Utilisateurs actifs</h3>
            <p style="font-size:24px; font-weight:bold;">{{ stats.active_users }}</p>
        </div>

        <div style="flex:1; min-width:200px; padding:20px; border:1px solid #ddd; border-radius:8px;">
            <h3>Projets actifs</h3>
            <p style="font-size:24px; font-weight:bold;">{{ stats.active_projects }}</p>
        </div>

        <div style="flex:1; min-width:200px; padding:20px; border:1px solid #ddd; border-radius:8px;">
            <h3>Notifications non lues</h3>
            <p style="font-size:24px; font-weight:bold;">{{ stats.unread_notifications }}</p>
        </div>

        <div style="flex:1; min-width:200px; padding:20px; border:1px solid #ddd; border-radius:8px;">
            <h3>Paiements du mois</h3>
            <p style="font-size:24px; font-weight:bold;">{{ stats.month_payments }} €</p>
        </div>

    </div>

    <h2 style="margin-top:40px;">Activité récente</h2>

    <ul>
        {% for item in recent_activity %}
            <li>
                <strong>{{ item.type|capitalize }}</strong> — {{ item.description }}
                ({{ item.created_at|date('d/m/Y H:i') }})
            </li>
        {% endfor %}
    </ul>

    <p style="margin-top:20px;">
        <a href="{{ path('home_activity') }}">Voir toute l’activité →</a>
    </p>

</div>
{% endblock %}
