{% extends 'base/layout.html.twig' %}

{% set page_title = project.name %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: project.name,
        content: '
            <p>' ~ project.description ~ '</p>
            <p>Statut : ' ~ include("components/badge.html.twig", { type: project.status, label: project.status|capitalize }) ~ '</p>
        '
    } %}

    <div style="margin-bottom:20px; display:flex; gap:10px;">
        <a href="/projects/{{ project.id }}/edit" style="
            padding:10px 16px;
            background:#ff9800;
            border-radius:8px;
            color:#fff;
            text-decoration:none;
            font-size:14px;
        ">Modifier</a>

        <a href="javascript:void(0)" onclick="middoOpenModal('delete-{{ project.id }}')" style="
            padding:10px 16px;
            background:#f44336;
            border-radius:8px;
            color:#fff;
            text-decoration:none;
            font-size:14px;
        ">Supprimer</a>
    </div>

    <h2 style="margin-bottom:15px;">Informations du projet</h2>

    {% include 'components/table.html.twig' with {
        headers: ['Champ', 'Valeur'],
        rows: [
            ['Nom', project.name],
            ['Description', project.description],
            ['Statut', include('components/badge.html.twig', { type: project.status, label: project.status|capitalize })],
            ['Créé le', project.created_at|date('d/m/Y H:i')],
            ['Mis à jour le', project.updated_at|date('d/m/Y H:i')]
        ]
    } %}

    {% include 'components/modal.html.twig' with {
        modal_id: 'delete-' ~ project.id,
        title: 'Supprimer le projet',
        message: 'Es-tu sûr de vouloir supprimer ce projet ?<br><br><strong>' ~ project.name ~ '</strong>',
        confirm_label: 'Supprimer',
        confirm_action: "window.location='/projects/" ~ project.id ~ "/delete';"
    } %}

{% endblock %}
