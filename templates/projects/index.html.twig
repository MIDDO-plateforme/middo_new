{% extends 'base/layout.html.twig' %}

{% set page_title = 'Projets' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'Gestion des projets',
        content: '
            Voici la liste de tous les projets enregistrés dans MIDDO OS.  
            Tu peux en créer de nouveaux, les modifier, ou les supprimer.
        '
    } %}

    {% if success is defined and success %}
        {% include 'components/alert.html.twig' with {
            type: 'success',
            title: 'Succès',
            message: success
        } %}
    {% endif %}

    {% if error is defined and error %}
        {% include 'components/alert.html.twig' with {
            type: 'danger',
            title: 'Erreur',
            message: error
        } %}
    {% endif %}

    <div style="margin-bottom:20px; text-align:right;">
        <a href="/projects/create" style="
            padding:10px 16px;
            background:#4caf50;
            border-radius:8px;
            color:#fff;
            text-decoration:none;
            font-size:14px;
        ">+ Nouveau projet</a>
    </div>

    {% set rows = [] %}

    {% for project in projects %}
        {% set status_type =
            project.status == 'active' ? 'success' :
            (project.status == 'pending' ? 'warning' : 'danger')
        %}

        {% set rows = rows|merge([[
            project.name,
            project.description,
            include('components/badge.html.twig', { type: status_type, label: project.status|capitalize }),
            project.created_at|date('d/m/Y'),
            '
                <a href="/projects/' ~ project.id ~ '" style="color:#2196f3;">Voir</a> |
                <a href="/projects/' ~ project.id ~ '/edit" style="color:#ff9800;">Modifier</a> |
                <a href="javascript:void(0)" onclick="middoOpenModal(\'delete-' ~ project.id ~ '\')" style="color:#f44336;">Supprimer</a>
            '
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['Nom', 'Description', 'Statut', 'Créé le', 'Actions'],
        rows: rows
    } %}

    {% for project in projects %}
        {% include 'components/modal.html.twig' with {
            modal_id: 'delete-' ~ project.id,
            title: 'Supprimer le projet',
            message: 'Es-tu sûr de vouloir supprimer ce projet ?<br><br><strong>' ~ project.name ~ '</strong>',
            confirm_label: 'Supprimer',
            confirm_action: "window.location='/projects/" ~ project.id ~ "/delete';"
        } %}
    {% endfor %}

{% endblock %}
