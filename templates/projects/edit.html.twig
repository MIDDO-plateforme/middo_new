{% extends 'base/layout.html.twig' %}

{% set page_title = 'Modifier le projet' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'Modifier le projet',
        content: '
            Mets à jour les informations du projet ci-dessous.  
            Les modifications seront appliquées immédiatement après validation.
        '
    } %}

    {% if error is defined and error %}
        {% include 'components/alert.html.twig' with {
            type: 'danger',
            title: 'Erreur',
            message: error
        } %}
    {% endif %}

    {% if success is defined and success %}
        {% include 'components/alert.html.twig' with {
            type: 'success',
            title: 'Succès',
            message: success
        } %}
    {% endif %}

    <form method="post" action="/projects/{{ project.id }}/edit" style="display:flex; flex-direction:column; gap:20px; max-width:600px;">

        <div>
            <label>Nom du projet</label>
            <input type="text" name="name" value="{{ project.name }}" required style="
                width:100%;
                padding:12px;
                border-radius:8px;
                border:1px solid #333;
                background:#1b1b1b;
                color:#eee;
                margin-top:5px;
            ">
        </div>

        <div>
            <label>Description</label>
            <textarea name="description" required rows="4" style="
                width:100%;
                padding:12px;
                border-radius:8px;
                border:1px solid #333;
                background:#1b1b1b;
                color:#eee;
                margin-top:5px;
            ">{{ project.description }}</textarea>
        </div>

        <div>
            <label>Statut</label>
            <select name="status" required style="
                width:100%;
                padding:12px;
                border-radius:8px;
                border:1px solid #333;
                background:#1b1b1b;
                color:#eee;
                margin-top:5px;
            ">
                <option value="active"   {% if project.status == 'active' %}selected{% endif %}>Actif</option>
                <option value="pending"  {% if project.status == 'pending' %}selected{% endif %}>En attente</option>
                <option value="disabled" {% if project.status == 'disabled' %}selected{% endif %}>Désactivé</option>
            </select>
        </div>

        <button type="submit" style="
            padding:12px;
            background:#2196f3;
            border:none;
            border-radius:8px;
            color:#fff;
            font-size:15px;
            cursor:pointer;
            transition:0.2s;
        "
            onmouseover="this.style.opacity='0.85'"
            onmouseout="this.style.opacity='1'"
        >
            Enregistrer les modifications
        </button>

    </form>

{% endblock %}
