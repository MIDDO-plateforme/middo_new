{% extends 'layout/layout.html.twig' %}

{% block title %}Préférences IA — MIDDO{% endblock %}
{% block page_title %}Préférences IA{% endblock %}

{% block content %}

<div class="card">
    <h2>Personnalisation IA</h2>

    {{ form_start(form) }}

        <div class="form-group">
            {{ form_label(form.provider) }}
            {{ form_widget(form.provider) }}
        </div>

        <div class="form-group">
            {{ form_label(form.model) }}
            {{ form_widget(form.model) }}
        </div>

        <div class="form-group">
            {{ form_label(form.tone) }}
            {{ form_widget(form.tone) }}
        </div>

        <div class="form-group">
            {{ form_label(form.detail) }}
            {{ form_widget(form.detail) }}
        </div>

        <div class="form-group">
            {{ form_label(form.language) }}
            {{ form_widget(form.language) }}
        </div>

        <button class="btn primary">Enregistrer</button>

    {{ form_end(form) }}
</div>

{% endblock %}
