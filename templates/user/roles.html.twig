{% extends 'base.html.twig' %}

{% block title %}Rôles utilisateur{% endblock %}

{% block body %}
<div style="padding:20px; max-width:700px; margin:auto;">

    <h1>Rôles de {{ user.name }}</h1>

    <form action="{{ path('user_roles_update', {id: user.id}) }}" method="POST">

        <label>Nouveau rôle :</label><br>
        <input type="text" name="role" value="{{ user.role }}"><br><br>

        <button type="submit">Mettre à jour</button>
    </form>

</div>
{% endblock %}
