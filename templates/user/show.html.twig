{% extends 'base.html.twig' %}

{% block title %}Profil utilisateur{% endblock %}

{% block body %}
<div style="padding:20px; max-width:700px; margin:auto;">

    <h1>Profil de {{ user.name }}</h1>

    <ul>
        <li>ID : {{ user.id }}</li>
        <li>Email : {{ user.email }}</li>
        <li>Rôle : {{ user.role }}</li>
        <li>Créé le : {{ user.created_at|date('d/m/Y') }}</li>
        <li>Mis à jour le : {{ user.updated_at|date('d/m/Y') }}</li>
    </ul>

    <p>
        <a href="{{ path('user_edit', {id: user.id}) }}">Modifier</a> |
        <a href="{{ path('user_roles', {id: user.id}) }}">Gérer les rôles</a>
    </p>

</div>
{% endblock %}
