{% extends 'base/layout.html.twig' %}

{% set page_title = 'Logs système' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'Logs système',
        content: '
            Voici l&apos;historique des événements système : erreurs, avertissements, informations et diagnostics.  
            Ces logs permettent de surveiller la stabilité et le comportement de MIDDO OS.
        '
    } %}

    {% if success is defined and success %}
        {% include 'components/alert.html.twig' with {
            type: 'success',
            title: 'Succès',
            message: success
        } %}
    {% endif %}

    {% if error is defined and error %}
        {% include 'components/alert.html.twig' with {
            type: 'danger',
            title: 'Erreur',
            message: error
        } %}
    {% endif %}

    <h2 style="margin-bottom:15px;">Historique des logs</h2>

    {% set rows = [] %}

    {% for log in logs %}
        {% set type_color =
            log.level == 'error' ? 'danger' :
            (log.level == 'warning' ? 'warning' :
            (log.level == 'info' ? 'info' : 'secondary'))
        %}

        {% set rows = rows|merge([[
            log.level|upper,
            log.message,
            log.context,
            log.created_at|date('d/m/Y H:i'),
            include('components/badge.html.twig', { type: type_color, label: log.level|capitalize })
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['Niveau', 'Message', 'Contexte', 'Date', 'Statut'],
        rows: rows
    } %}

{% endblock %}

