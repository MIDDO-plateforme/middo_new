{% extends 'base/layout.html.twig' %}

{% set page_title = 'Logs de sécurité' %}

{% block page_content %}

    {% include 'components/card.html.twig' with {
        title: 'Logs de sécurité',
        content: '
            Voici l&apos;historique des actions liées à ton compte : connexions, déconnexions, erreurs, tentatives échouées, etc.
            Ces informations te permettent de surveiller l&apos;activité et de détecter toute anomalie.
        '
    } %}

    {% if success is defined and success %}
        {% include 'components/alert.html.twig' with {
            type: 'success',
            title: 'Succès',
            message: success
        } %}
    {% endif %}

    {% if error is defined and error %}
        {% include 'components/alert.html.twig' with {
            type: 'danger',
            title: 'Erreur',
            message: error
        } %}
    {% endif %}

    <h2 style="margin-bottom:15px;">Historique des logs</h2>

    {% set rows = [] %}

    {% for log in logs %}
        {% set status_type = 
            log.status == 'success' ? 'success' :
            (log.status == 'failed' ? 'danger' : 'info')
        %}

        {% set rows = rows|merge([[
            log.ip,
            log.action,
            log.created_at|date('d/m/Y H:i'),
            include('components/badge.html.twig', { type: status_type, label: log.status|capitalize })
        ]]) %}
    {% endfor %}

    {% include 'components/table.html.twig' with {
        headers: ['IP', 'Action', 'Date', 'Statut'],
        rows: rows
    } %}

{% endblock %}
