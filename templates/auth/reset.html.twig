{% extends 'base/layout.html.twig' %}

{% set page_title = 'Réinitialiser le mot de passe' %}

{% block page_content %}

<div style="
    max-width:420px;
    margin:40px auto;
    background:#141414;
    border:1px solid #222;
    padding:30px;
    border-radius:14px;
    box-shadow:0 10px 30px rgba(0,0,0,0.4);
    animation: fadeIn 0.4s ease;
">

    <h2 style="margin-bottom:20px; text-align:center;">Réinitialiser le mot de passe</h2>

    {% if error is defined and error %}
        {% include 'components/alert.html.twig' with {
            type: 'danger',
            title: 'Erreur',
            message: error
        } %}
    {% endif %}

    {% if success is defined and success %}
        {% include 'components/alert.html.twig' with {
            type: 'success',
            title: 'Email envoyé',
            message: success
        } %}
    {% endif %}

    <form method="post" action="/auth/reset" style="display:flex; flex-direction:column; gap:15px;">

        <div>
            <label>Adresse email</label>
            <input type="email" name="email" required style="
                width:100%;
                padding:12px;
                border-radius:8px;
                border:1px solid #333;
                background:#1b1b1b;
                color:#eee;
                margin-top:5px;
            ">
        </div>

        <button type="submit" style="
            padding:12px;
            background:#2196f3;
            border:none;
            border-radius:8px;
            color:#fff;
            font-size:15px;
            cursor:pointer;
            transition:0.2s;
        "
            onmouseover="this.style.opacity='0.85'"
            onmouseout="this.style.opacity='1'"
        >
            Envoyer le lien de réinitialisation
        </button>

    </form>

    <div style="margin-top:20px; text-align:center; font-size:14px; color:#aaa;">
        <p><a href="/auth/login" style="color:#4caf50;">Retour à la connexion</a></p>
    </div>

</div>

{% endblock %}
